-- 10.1 Active vessel overview with last position
CREATE OR REPLACE VIEW vw_active_vessels AS
SELECT
    v.vessel_id,
    v.vessel_name,
    v.mmsi,
    v.imo_number,
    v.call_sign,
    v.flag_state,
    vt.type_name,
    vt.type_category,
    op.operator_name,
    v.year_built,
    v.deadweight_tonnes,
    v.gross_tonnage,
    v.service_speed_kn,
    v.status,
    v.fuel_type,
    -- Last known position (subquery)
    (SELECT ap.latitude FROM ais_positions ap
     WHERE ap.vessel_id = v.vessel_id
     AND ap.recorded_at = (SELECT MAX(ap2.recorded_at) FROM ais_positions ap2 WHERE ap2.vessel_id = v.vessel_id)
     AND ROWNUM = 1) AS last_latitude,
    (SELECT ap.longitude FROM ais_positions ap
     WHERE ap.vessel_id = v.vessel_id
     AND ap.recorded_at = (SELECT MAX(ap2.recorded_at) FROM ais_positions ap2 WHERE ap2.vessel_id = v.vessel_id)
     AND ROWNUM = 1) AS last_longitude,
    (SELECT ap.speed_over_ground FROM ais_positions ap
     WHERE ap.vessel_id = v.vessel_id
     AND ap.recorded_at = (SELECT MAX(ap2.recorded_at) FROM ais_positions ap2 WHERE ap2.vessel_id = v.vessel_id)
     AND ROWNUM = 1) AS current_speed_kn,
    (SELECT ap.recorded_at FROM ais_positions ap
     WHERE ap.vessel_id = v.vessel_id
     AND ap.recorded_at = (SELECT MAX(ap2.recorded_at) FROM ais_positions ap2 WHERE ap2.vessel_id = v.vessel_id)
     AND ROWNUM = 1) AS last_ais_report
FROM vessels v
JOIN vessel_types vt ON v.type_code = vt.type_code
JOIN operators    op ON v.operator_id = op.operator_id
WHERE v.status NOT IN ('DECOMMISSIONED','MUSEUM');

-- 10.2 Fleet summary by type
CREATE OR REPLACE VIEW vw_fleet_summary AS
SELECT
    vt.type_category,
    vt.type_name,
    COUNT(v.vessel_id)                                          AS vessel_count,
    SUM(v.deadweight_tonnes)                                    AS total_dwt,
    AVG(v.deadweight_tonnes)                                    AS avg_dwt,
    ROUND(AVG(EXTRACT(YEAR FROM SYSDATE) - v.year_built), 1)   AS avg_age_years,
    SUM(CASE WHEN v.status = 'ACTIVE'    THEN 1 ELSE 0 END)    AS active_count,
    SUM(CASE WHEN v.status = 'MOORED'    THEN 1 ELSE 0 END)    AS moored_count,
    SUM(CASE WHEN v.status = 'DRY_DOCK' THEN 1 ELSE 0 END)    AS drydock_count
FROM vessels v
JOIN vessel_types vt ON v.type_code = vt.type_code
WHERE v.status <> 'DECOMMISSIONED'
GROUP BY vt.type_category, vt.type_name
ORDER BY vt.type_category, vessel_count DESC;

-- 10.3 Current voyage status
CREATE OR REPLACE VIEW vw_voyage_status AS
SELECT
    voy.voyage_number,
    v.vessel_name,
    v.mmsi,
    vt.type_name    AS vessel_type,
    po.port_name    AS origin_port,
    po.country_code AS origin_country,
    pd.port_name    AS destination_port,
    pd.country_code AS destination_country,
    voy.atd,
    voy.eta,
    voy.voyage_status,
    voy.cargo_type,
    voy.cargo_tonnes,
    voy.passenger_count,
    voy.vehicle_count,
    CASE WHEN voy.voyage_status = 'UNDERWAY' AND voy.eta IS NOT NULL
         THEN ROUND((voy.eta - SYSTIMESTAMP) * 24, 1)
         ELSE NULL
    END AS hours_to_arrival
FROM voyages voy
JOIN vessels      v  ON voy.vessel_id           = v.vessel_id
JOIN vessel_types vt ON v.type_code             = vt.type_code
JOIN ports        po ON voy.origin_port_id      = po.port_id
JOIN ports        pd ON voy.destination_port_id = pd.port_id
ORDER BY voy.atd DESC;

-- 10.4 Port activity (recent calls)
CREATE OR REPLACE VIEW vw_port_activity AS
SELECT
    p.port_name,
    p.country_code,
    p.port_type,
    COUNT(pc.port_call_id)                                                      AS total_calls,
    SUM(CASE WHEN pc.departure_time IS NULL THEN 1 ELSE 0 END)                 AS vessels_in_port,
    SUM(NVL(pc.cargo_loaded_t, 0) + NVL(pc.cargo_discharged_t, 0))             AS total_cargo_handled_t,
    ROUND(AVG(pc.departure_time - pc.arrival_time) * 24, 1)                    AS avg_turnaround_hr,
    MAX(pc.arrival_time)                                                        AS last_vessel_arrival
FROM ports p
LEFT JOIN port_calls pc ON p.port_id = pc.port_id
    AND pc.arrival_time >= SYSDATE - 90    -- last 90 days
GROUP BY p.port_id, p.port_name, p.country_code, p.port_type
ORDER BY total_calls DESC NULLS LAST;

-- 10.5 Aging fleet alert view
CREATE OR REPLACE VIEW vw_aging_fleet AS
SELECT
    v.vessel_name,
    v.mmsi,
    v.imo_number,
    vt.type_name,
    v.year_built,
    EXTRACT(YEAR FROM SYSDATE) - v.year_built   AS age_years,
    v.status,
    v.fuel_type,
    op.operator_name,
    CASE
        WHEN (EXTRACT(YEAR FROM SYSDATE) - v.year_built) >= 35 THEN 'CRITICAL — DECOMMISSION CANDIDATE'
        WHEN (EXTRACT(YEAR FROM SYSDATE) - v.year_built) >= 25 THEN 'HIGH — MAJOR REFIT REQUIRED'
        WHEN (EXTRACT(YEAR FROM SYSDATE) - v.year_built) >= 15 THEN 'MEDIUM — SCHEDULED MAINTENANCE'
        ELSE 'LOW — WITHIN NORMAL SERVICE LIFE'
    END AS age_risk_level
FROM vessels v
JOIN vessel_types vt ON v.type_code    = vt.type_code
JOIN operators    op ON v.operator_id  = op.operator_id
WHERE v.status NOT IN ('DECOMMISSIONED','MUSEUM')
ORDER BY age_years DESC;


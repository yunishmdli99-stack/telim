-- 12.1 Update updated_at on vessels
CREATE OR REPLACE TRIGGER trg_vessels_updated_at
BEFORE UPDATE ON vessels
FOR EACH ROW
BEGIN
    :NEW.updated_at := SYSTIMESTAMP;
END;
/

-- 12.2 Audit trigger for vessels table
CREATE OR REPLACE TRIGGER trg_vessels_audit
AFTER INSERT OR UPDATE OR DELETE ON vessels
FOR EACH ROW
DECLARE
    v_action    VARCHAR2(10);
    v_old_vals  CLOB := NULL;
    v_new_vals  CLOB := NULL;
    v_rec_id    NUMBER;
BEGIN
    IF INSERTING THEN
        v_action := 'INSERT';
        v_rec_id := :NEW.vessel_id;
        v_new_vals := 'name=' || :NEW.vessel_name || ', mmsi=' || :NEW.mmsi || ', status=' || :NEW.status;
    ELSIF UPDATING THEN
        v_action := 'UPDATE';
        v_rec_id := :NEW.vessel_id;
        v_old_vals := 'name=' || :OLD.vessel_name || ', status=' || :OLD.status || ', fuel=' || :OLD.fuel_type;
        v_new_vals := 'name=' || :NEW.vessel_name || ', status=' || :NEW.status || ', fuel=' || :NEW.fuel_type;
    ELSE
        v_action := 'DELETE';
        v_rec_id := :OLD.vessel_id;
        v_old_vals := 'name=' || :OLD.vessel_name || ', mmsi=' || :OLD.mmsi;
    END IF;

    INSERT INTO audit_log (table_name, record_id, action_type, old_values, new_values)
    VALUES ('VESSELS', v_rec_id, v_action, v_old_vals, v_new_vals);
END;
/

-- 12.3 Auto-generate voyage number if not supplied
CREATE OR REPLACE TRIGGER trg_voyages_number
BEFORE INSERT ON voyages
FOR EACH ROW
BEGIN
    IF :NEW.voyage_number IS NULL OR :NEW.voyage_number = '' THEN
        :NEW.voyage_number := 'VYG-' || TO_CHAR(SYSTIMESTAMP,'YYYY') || '-' ||
                              LPAD(seq_voyage_id.CURRVAL, 6, '0');
    END IF;
    :NEW.updated_at := SYSTIMESTAMP;
END;
/

-- 12.4 Prevent inserting positions outside Caspian Sea bounding box (extended)
CREATE OR REPLACE TRIGGER trg_ais_position_validate
BEFORE INSERT ON ais_positions
FOR EACH ROW
BEGIN
    IF :NEW.latitude  NOT BETWEEN 35.0 AND 48.0 OR
       :NEW.longitude NOT BETWEEN 48.0 AND 56.0 THEN
        RAISE_APPLICATION_ERROR(-20050,
            'AIS position (' || :NEW.latitude || ', ' || :NEW.longitude ||
            ') is outside Caspian Sea geographic bounds');
    END IF;
END;
/


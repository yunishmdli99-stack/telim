-- =============================================================================
-- AZERBAIJAN MARINE TRAFFIC DATABASE
-- Oracle SQL Backend — DDL + DML + Stored Procedures + Views + Triggers
-- Based on ASCO (Azerbaijan Caspian Shipping Company) Fleet Data
-- Caspian Sea AIS / MarineTraffic Registry
-- =============================================================================

-- =============================================================================
-- SECTION 1: SEQUENCE DEFINITIONS
-- =============================================================================

CREATE SEQUENCE seq_vessel_id       START WITH 1 INCREMENT BY 1 NOCACHE NOCYCLE;
CREATE SEQUENCE seq_port_id         START WITH 1 INCREMENT BY 1 NOCACHE NOCYCLE;
CREATE SEQUENCE seq_voyage_id       START WITH 1 INCREMENT BY 1 NOCACHE NOCYCLE;
CREATE SEQUENCE seq_position_id     START WITH 1 INCREMENT BY 1 NOCACHE NOCYCLE;
CREATE SEQUENCE seq_port_call_id    START WITH 1 INCREMENT BY 1 NOCACHE NOCYCLE;
CREATE SEQUENCE seq_incident_id     START WITH 1 INCREMENT BY 1 NOCACHE NOCYCLE;
CREATE SEQUENCE seq_operator_id     START WITH 1 INCREMENT BY 1 NOCACHE NOCYCLE;
CREATE SEQUENCE seq_audit_id        START WITH 1 INCREMENT BY 1 NOCACHE NOCYCLE;
CREATE SEQUENCE seq_cargo_id        START WITH 1 INCREMENT BY 1 NOCACHE NOCYCLE;

-- =============================================================================
-- SECTION 2: TABLE DEFINITIONS
-- =============================================================================

-- -----------------------------------------------------------------------------
-- 2.1 OPERATORS (shipping companies / fleet managers)
-- -----------------------------------------------------------------------------
CREATE TABLE operators (
    operator_id         NUMBER          DEFAULT seq_operator_id.NEXTVAL PRIMARY KEY,
    operator_code       VARCHAR2(10)    NOT NULL UNIQUE,
    operator_name       VARCHAR2(200)   NOT NULL,
    country_code        CHAR(2)         NOT NULL,
    hq_city             VARCHAR2(100),
    website             VARCHAR2(255),
    imo_company_number  VARCHAR2(20),
    is_active           CHAR(1)         DEFAULT 'Y' NOT NULL CHECK (is_active IN ('Y','N')),
    created_at          TIMESTAMP       DEFAULT SYSTIMESTAMP NOT NULL,
    updated_at          TIMESTAMP       DEFAULT SYSTIMESTAMP NOT NULL,
    CONSTRAINT chk_op_country CHECK (country_code = UPPER(country_code))
);

-- -----------------------------------------------------------------------------
-- 2.2 VESSEL TYPES (lookup)
-- -----------------------------------------------------------------------------
CREATE TABLE vessel_types (
    type_code           VARCHAR2(20)    PRIMARY KEY,
    type_name           VARCHAR2(100)   NOT NULL,
    type_category       VARCHAR2(50)    NOT NULL, -- MERCHANT, OFFSHORE, AUXILIARY, NAVAL
    description         VARCHAR2(500)
);

-- -----------------------------------------------------------------------------
-- 2.3 VESSELS (core registry)
-- -----------------------------------------------------------------------------
CREATE TABLE vessels (
    vessel_id           NUMBER          DEFAULT seq_vessel_id.NEXTVAL PRIMARY KEY,
    vessel_name         VARCHAR2(200)   NOT NULL,
    mmsi                VARCHAR2(9)     NOT NULL UNIQUE,
    imo_number          VARCHAR2(7)     UNIQUE,
    call_sign           VARCHAR2(10)    UNIQUE,
    flag_state          CHAR(2)         NOT NULL DEFAULT 'AZ',
    type_code           VARCHAR2(20)    NOT NULL,
    operator_id         NUMBER          NOT NULL,
    year_built          NUMBER(4)       NOT NULL,
    shipyard            VARCHAR2(200),
    length_m            NUMBER(7,2),
    beam_m              NUMBER(6,2),
    draft_max_m         NUMBER(5,2),
    deadweight_tonnes   NUMBER(10,2),
    gross_tonnage       NUMBER(10,2),
    net_tonnage         NUMBER(10,2),
    passenger_capacity  NUMBER(5),
    vehicle_capacity    NUMBER(5),
    service_speed_kn    NUMBER(5,2),
    max_speed_kn        NUMBER(5,2),
    main_engine         VARCHAR2(200),
    engine_power_kw     NUMBER(8,2),
    fuel_type           VARCHAR2(50)    DEFAULT 'HFO',
    status              VARCHAR2(20)    DEFAULT 'ACTIVE' NOT NULL,
    vessel_notes        VARCHAR2(1000),
    created_at          TIMESTAMP       DEFAULT SYSTIMESTAMP NOT NULL,
    updated_at          TIMESTAMP       DEFAULT SYSTIMESTAMP NOT NULL,
    CONSTRAINT fk_vessel_type     FOREIGN KEY (type_code)    REFERENCES vessel_types(type_code),
    CONSTRAINT fk_vessel_operator FOREIGN KEY (operator_id)  REFERENCES operators(operator_id),
    CONSTRAINT chk_vessel_status  CHECK (status IN ('ACTIVE','MOORED','DRY_DOCK','DECOMMISSIONED','MUSEUM')),
    CONSTRAINT chk_year_built     CHECK (year_built BETWEEN 1850 AND 2030),
    CONSTRAINT chk_mmsi_length    CHECK (LENGTH(mmsi) = 9),
    CONSTRAINT chk_imo_length     CHECK (imo_number IS NULL OR LENGTH(imo_number) = 7),
    CONSTRAINT chk_flag_upper     CHECK (flag_state = UPPER(flag_state)),
    CONSTRAINT chk_fuel_type      CHECK (fuel_type IN ('HFO','MGO','LNG','METHANOL','ELECTRIC','HYBRID'))
);

-- -----------------------------------------------------------------------------
-- 2.4 PORTS
-- -----------------------------------------------------------------------------
CREATE TABLE ports (
    port_id             NUMBER          DEFAULT seq_port_id.NEXTVAL PRIMARY KEY,
    port_code           VARCHAR2(10)    NOT NULL UNIQUE,   -- UN/LOCODE style
    port_name           VARCHAR2(200)   NOT NULL,
    country_code        CHAR(2)         NOT NULL,
    city                VARCHAR2(100),
    sea_area            VARCHAR2(100)   DEFAULT 'Caspian Sea',
    latitude            NUMBER(9,6)     NOT NULL,
    longitude           NUMBER(9,6)    NOT NULL,
    max_draft_m         NUMBER(5,2),
    max_vessel_length_m NUMBER(7,2),
    berths_count        NUMBER(5),
    port_type           VARCHAR2(50),  -- COMMERCIAL, OFFSHORE, FERRY, OIL_TERMINAL, FISHING
    is_active           CHAR(1)         DEFAULT 'Y' NOT NULL CHECK (is_active IN ('Y','N')),
    port_notes          VARCHAR2(1000),
    created_at          TIMESTAMP       DEFAULT SYSTIMESTAMP NOT NULL,
    CONSTRAINT chk_port_lat  CHECK (latitude  BETWEEN -90  AND 90),
    CONSTRAINT chk_port_lon  CHECK (longitude BETWEEN -180 AND 180),
    CONSTRAINT chk_port_type CHECK (port_type IN ('COMMERCIAL','OFFSHORE','FERRY','OIL_TERMINAL','FISHING','NAVAL','MIXED'))
);

-- -----------------------------------------------------------------------------
-- 2.5 ROUTES (standard Caspian shipping lanes)
-- -----------------------------------------------------------------------------
CREATE TABLE routes (
    route_id            NUMBER          GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    route_code          VARCHAR2(20)    NOT NULL UNIQUE,
    origin_port_id      NUMBER          NOT NULL,
    destination_port_id NUMBER          NOT NULL,
    distance_nm         NUMBER(8,2),
    typical_duration_hr NUMBER(6,2),
    route_type          VARCHAR2(30),   -- FERRY, CARGO, TANKER, OFFSHORE_SUPPORT
    is_active           CHAR(1)         DEFAULT 'Y' CHECK (is_active IN ('Y','N')),
    CONSTRAINT fk_route_origin FOREIGN KEY (origin_port_id)      REFERENCES ports(port_id),
    CONSTRAINT fk_route_dest   FOREIGN KEY (destination_port_id) REFERENCES ports(port_id),
    CONSTRAINT chk_route_ports CHECK (origin_port_id <> destination_port_id)
);

-- -----------------------------------------------------------------------------
-- 2.6 VOYAGES
-- -----------------------------------------------------------------------------
CREATE TABLE voyages (
    voyage_id           NUMBER          DEFAULT seq_voyage_id.NEXTVAL PRIMARY KEY,
    voyage_number       VARCHAR2(30)    NOT NULL UNIQUE,
    vessel_id           NUMBER          NOT NULL,
    origin_port_id      NUMBER          NOT NULL,
    destination_port_id NUMBER          NOT NULL,
    etd                 TIMESTAMP,      -- Estimated Time of Departure
    atd                 TIMESTAMP,      -- Actual Time of Departure
    eta                 TIMESTAMP,      -- Estimated Time of Arrival
    ata                 TIMESTAMP,      -- Actual Time of Arrival
    voyage_status       VARCHAR2(20)    DEFAULT 'PLANNED' NOT NULL,
    cargo_type          VARCHAR2(100),
    cargo_tonnes        NUMBER(10,2),
    passenger_count     NUMBER(6),
    vehicle_count       NUMBER(6),
    voyage_notes        VARCHAR2(1000),
    created_at          TIMESTAMP       DEFAULT SYSTIMESTAMP NOT NULL,
    updated_at          TIMESTAMP       DEFAULT SYSTIMESTAMP NOT NULL,
    CONSTRAINT fk_voyage_vessel FOREIGN KEY (vessel_id)           REFERENCES vessels(vessel_id),
    CONSTRAINT fk_voyage_origin FOREIGN KEY (origin_port_id)      REFERENCES ports(port_id),
    CONSTRAINT fk_voyage_dest   FOREIGN KEY (destination_port_id) REFERENCES ports(port_id),
    CONSTRAINT chk_voyage_status CHECK (voyage_status IN ('PLANNED','UNDERWAY','COMPLETED','CANCELLED','DIVERTED')),
    CONSTRAINT chk_voyage_dates  CHECK (atd IS NULL OR eta IS NULL OR atd < eta)
);

-- -----------------------------------------------------------------------------
-- 2.7 AIS POSITION TRACKING
-- -----------------------------------------------------------------------------
CREATE TABLE ais_positions (
    position_id         NUMBER          DEFAULT seq_position_id.NEXTVAL PRIMARY KEY,
    vessel_id           NUMBER          NOT NULL,
    mmsi                VARCHAR2(9)     NOT NULL,
    recorded_at         TIMESTAMP       NOT NULL,
    latitude            NUMBER(9,6)     NOT NULL,
    longitude           NUMBER(9,6)     NOT NULL,
    speed_over_ground   NUMBER(5,2),    -- knots
    course_over_ground  NUMBER(6,2),    -- degrees 0-359.9
    true_heading        NUMBER(5,1),    -- degrees 0-359
    nav_status          VARCHAR2(50),
    rate_of_turn        NUMBER(7,2),
    ais_class           CHAR(1)         DEFAULT 'A' CHECK (ais_class IN ('A','B')),
    source              VARCHAR2(50)    DEFAULT 'AIS_TERRESTRIAL',
    CONSTRAINT fk_pos_vessel FOREIGN KEY (vessel_id) REFERENCES vessels(vessel_id),
    CONSTRAINT chk_pos_lat   CHECK (latitude  BETWEEN  35 AND  45),  -- Caspian Sea bounds
    CONSTRAINT chk_pos_lon   CHECK (longitude BETWEEN  48 AND  55),  -- Caspian Sea bounds
    CONSTRAINT chk_pos_sog   CHECK (speed_over_ground IS NULL OR speed_over_ground BETWEEN 0 AND 50),
    CONSTRAINT chk_pos_cog   CHECK (course_over_ground IS NULL OR course_over_ground BETWEEN 0 AND 360),
    CONSTRAINT chk_pos_src   CHECK (source IN ('AIS_TERRESTRIAL','AIS_SATELLITE','MANUAL','LRIT'))
)
PARTITION BY RANGE (recorded_at) (
    PARTITION pos_2023 VALUES LESS THAN (TIMESTAMP '2024-01-01 00:00:00'),
    PARTITION pos_2024 VALUES LESS THAN (TIMESTAMP '2025-01-01 00:00:00'),
    PARTITION pos_2025 VALUES LESS THAN (TIMESTAMP '2026-01-01 00:00:00'),
    PARTITION pos_2026 VALUES LESS THAN (TIMESTAMP '2027-01-01 00:00:00'),
    PARTITION pos_future VALUES LESS THAN (MAXVALUE)
);

-- -----------------------------------------------------------------------------
-- 2.8 PORT CALLS
-- -----------------------------------------------------------------------------
CREATE TABLE port_calls (
    port_call_id        NUMBER          DEFAULT seq_port_call_id.NEXTVAL PRIMARY KEY,
    vessel_id           NUMBER          NOT NULL,
    voyage_id           NUMBER,
    port_id             NUMBER          NOT NULL,
    arrival_time        TIMESTAMP,
    departure_time      TIMESTAMP,
    berth_number        VARCHAR2(20),
    call_purpose        VARCHAR2(100),  -- LOADING, DISCHARGING, BUNKERING, CREW_CHANGE, REPAIR, TRANSIT
    cargo_loaded_t      NUMBER(10,2),
    cargo_discharged_t  NUMBER(10,2),
    fuel_bunkered_t     NUMBER(8,2),
    call_notes          VARCHAR2(500),
    created_at          TIMESTAMP       DEFAULT SYSTIMESTAMP NOT NULL,
    CONSTRAINT fk_pc_vessel  FOREIGN KEY (vessel_id) REFERENCES vessels(vessel_id),
    CONSTRAINT fk_pc_voyage  FOREIGN KEY (voyage_id) REFERENCES voyages(voyage_id),
    CONSTRAINT fk_pc_port    FOREIGN KEY (port_id)   REFERENCES ports(port_id),
    CONSTRAINT chk_pc_dates  CHECK (arrival_time IS NULL OR departure_time IS NULL OR arrival_time <= departure_time),
    CONSTRAINT chk_pc_purpose CHECK (call_purpose IN ('LOADING','DISCHARGING','BUNKERING','CREW_CHANGE','REPAIR','TRANSIT','MIXED','PASSENGER'))
);

-- -----------------------------------------------------------------------------
-- 2.9 MARITIME INCIDENTS
-- -----------------------------------------------------------------------------
CREATE TABLE incidents (
    incident_id         NUMBER          DEFAULT seq_incident_id.NEXTVAL PRIMARY KEY,
    vessel_id           NUMBER          NOT NULL,
    voyage_id           NUMBER,
    incident_date       TIMESTAMP       NOT NULL,
    incident_type       VARCHAR2(50)    NOT NULL,
    severity            VARCHAR2(20)    DEFAULT 'MINOR' NOT NULL,
    latitude            NUMBER(9,6),
    longitude           NUMBER(9,6),
    description         VARCHAR2(2000)  NOT NULL,
    casualties          NUMBER(5)       DEFAULT 0,
    injuries            NUMBER(5)       DEFAULT 0,
    pollution_risk      CHAR(1)         DEFAULT 'N' CHECK (pollution_risk IN ('Y','N')),
    resolved            CHAR(1)         DEFAULT 'N' CHECK (resolved IN ('Y','N')),
    resolution_notes    VARCHAR2(1000),
    reported_to_imo     CHAR(1)         DEFAULT 'N' CHECK (reported_to_imo IN ('Y','N')),
    created_at          TIMESTAMP       DEFAULT SYSTIMESTAMP NOT NULL,
    CONSTRAINT fk_inc_vessel  FOREIGN KEY (vessel_id) REFERENCES vessels(vessel_id),
    CONSTRAINT fk_inc_voyage  FOREIGN KEY (voyage_id) REFERENCES voyages(voyage_id),
    CONSTRAINT chk_inc_type   CHECK (incident_type IN ('COLLISION','GROUNDING','FIRE','FLOODING','MECHANICAL','CARGO_SPILL','PIRACY','WEATHER','MAN_OVERBOARD','OTHER')),
    CONSTRAINT chk_inc_sev    CHECK (severity IN ('MINOR','MODERATE','SERIOUS','VERY_SERIOUS','CATASTROPHIC'))
);

-- -----------------------------------------------------------------------------
-- 2.10 CARGO MANIFESTS
-- -----------------------------------------------------------------------------
CREATE TABLE cargo_manifests (
    cargo_id            NUMBER          DEFAULT seq_cargo_id.NEXTVAL PRIMARY KEY,
    voyage_id           NUMBER          NOT NULL,
    cargo_type          VARCHAR2(100)   NOT NULL,
    commodity_code      VARCHAR2(20),
    quantity_tonnes     NUMBER(12,3),
    quantity_units      NUMBER(10),
    unit_type           VARCHAR2(30),   -- CONTAINER, VEHICLE, RAIL_WAGON, BARREL, TONNE
    origin_country      CHAR(2),
    destination_country CHAR(2),
    shipper_name        VARCHAR2(200),
    consignee_name      VARCHAR2(200),
    hazmat_class        VARCHAR2(10),
    manifest_notes      VARCHAR2(500),
    created_at          TIMESTAMP       DEFAULT SYSTIMESTAMP NOT NULL,
    CONSTRAINT fk_cargo_voyage FOREIGN KEY (voyage_id) REFERENCES voyages(voyage_id)
);

-- -----------------------------------------------------------------------------
-- 2.11 AUDIT LOG
-- -----------------------------------------------------------------------------
CREATE TABLE audit_log (
    audit_id            NUMBER          DEFAULT seq_audit_id.NEXTVAL PRIMARY KEY,
    table_name          VARCHAR2(50)    NOT NULL,
    record_id           NUMBER          NOT NULL,
    action_type         VARCHAR2(10)    NOT NULL CHECK (action_type IN ('INSERT','UPDATE','DELETE')),
    changed_by          VARCHAR2(100)   DEFAULT USER NOT NULL,
    changed_at          TIMESTAMP       DEFAULT SYSTIMESTAMP NOT NULL,
    old_values          CLOB,
    new_values          CLOB
);

-- =============================================================================
-- SECTION 3: INDEXES
-- =============================================================================

-- Vessels
CREATE INDEX idx_vessel_mmsi        ON vessels(mmsi);
CREATE INDEX idx_vessel_imo         ON vessels(imo_number);
CREATE INDEX idx_vessel_status      ON vessels(status);
CREATE INDEX idx_vessel_type        ON vessels(type_code);
CREATE INDEX idx_vessel_flag        ON vessels(flag_state);
CREATE INDEX idx_vessel_operator    ON vessels(operator_id);

-- AIS Positions (partitioned table)
CREATE INDEX idx_pos_vessel_time    ON ais_positions(vessel_id, recorded_at);
CREATE INDEX idx_pos_mmsi_time      ON ais_positions(mmsi, recorded_at);

-- Voyages
CREATE INDEX idx_voyage_vessel      ON voyages(vessel_id);
CREATE INDEX idx_voyage_status      ON voyages(voyage_status);
CREATE INDEX idx_voyage_origin      ON voyages(origin_port_id);
CREATE INDEX idx_voyage_dest        ON voyages(destination_port_id);
CREATE INDEX idx_voyage_atd         ON voyages(atd);

-- Port Calls
CREATE INDEX idx_pc_vessel          ON port_calls(vessel_id);
CREATE INDEX idx_pc_port            ON port_calls(port_id);
CREATE INDEX idx_pc_arrival         ON port_calls(arrival_time);

-- Incidents
CREATE INDEX idx_inc_vessel         ON incidents(vessel_id);
CREATE INDEX idx_inc_date           ON incidents(incident_date);
CREATE INDEX idx_inc_type           ON incidents(incident_type);


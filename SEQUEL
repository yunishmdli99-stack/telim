-- 11.1 FUNCTION: Calculate distance between two Caspian coordinates (Haversine)
CREATE OR REPLACE FUNCTION fn_haversine_nm (
    p_lat1  NUMBER,
    p_lon1  NUMBER,
    p_lat2  NUMBER,
    p_lon2  NUMBER
) RETURN NUMBER DETERMINISTIC IS
    v_r         CONSTANT NUMBER := 3440.065;  -- Earth radius in nautical miles
    v_dlat      NUMBER;
    v_dlon      NUMBER;
    v_a         NUMBER;
    v_c         NUMBER;
BEGIN
    v_dlat := (p_lat2 - p_lat1) * 3.14159265358979 / 180;
    v_dlon := (p_lon2 - p_lon1) * 3.14159265358979 / 180;
    v_a := POWER(SIN(v_dlat / 2), 2) +
           COS(p_lat1 * 3.14159265358979 / 180) *
           COS(p_lat2 * 3.14159265358979 / 180) *
           POWER(SIN(v_dlon / 2), 2);
    v_c := 2 * ASIN(SQRT(v_a));
    RETURN ROUND(v_r * v_c, 2);
END fn_haversine_nm;
/

-- 11.2 FUNCTION: Get vessel status label
CREATE OR REPLACE FUNCTION fn_vessel_status_label (p_status VARCHAR2) RETURN VARCHAR2 DETERMINISTIC IS
BEGIN
    RETURN CASE p_status
        WHEN 'ACTIVE'          THEN 'Active - Operational'
        WHEN 'MOORED'          THEN 'Moored / Standby'
        WHEN 'DRY_DOCK'        THEN 'In Dry Dock / Refit'
        WHEN 'DECOMMISSIONED'  THEN 'Decommissioned'
        WHEN 'MUSEUM'          THEN 'Museum Ship'
        ELSE 'Unknown'
    END;
END fn_vessel_status_label;
/

-- 11.3 PROCEDURE: Record new AIS position
CREATE OR REPLACE PROCEDURE sp_record_ais_position (
    p_mmsi          IN VARCHAR2,
    p_recorded_at   IN TIMESTAMP,
    p_latitude      IN NUMBER,
    p_longitude     IN NUMBER,
    p_sog           IN NUMBER DEFAULT NULL,
    p_cog           IN NUMBER DEFAULT NULL,
    p_heading       IN NUMBER DEFAULT NULL,
    p_nav_status    IN VARCHAR2 DEFAULT NULL,
    p_source        IN VARCHAR2 DEFAULT 'AIS_TERRESTRIAL'
) AS
    v_vessel_id     vessels.vessel_id%TYPE;
    v_count         NUMBER;
BEGIN
    -- Validate MMSI
    SELECT vessel_id INTO v_vessel_id
    FROM vessels WHERE mmsi = p_mmsi;

    -- Check duplicate (same vessel, same timestamp)
    SELECT COUNT(*) INTO v_count
    FROM ais_positions
    WHERE vessel_id = v_vessel_id AND recorded_at = p_recorded_at;

    IF v_count = 0 THEN
        INSERT INTO ais_positions (
            vessel_id, mmsi, recorded_at, latitude, longitude,
            speed_over_ground, course_over_ground, true_heading,
            nav_status, source
        ) VALUES (
            v_vessel_id, p_mmsi, p_recorded_at, p_latitude, p_longitude,
            p_sog, p_cog, p_heading, p_nav_status, p_source
        );
        COMMIT;
    END IF;

EXCEPTION
    WHEN NO_DATA_FOUND THEN
        RAISE_APPLICATION_ERROR(-20001, 'MMSI ' || p_mmsi || ' not found in vessel registry');
    WHEN OTHERS THEN
        ROLLBACK;
        RAISE;
END sp_record_ais_position;
/

-- 11.4 PROCEDURE: Register a voyage departure
CREATE OR REPLACE PROCEDURE sp_depart_voyage (
    p_voyage_number     IN VARCHAR2,
    p_actual_departure  IN TIMESTAMP DEFAULT SYSTIMESTAMP
) AS
    v_voyage_id     voyages.voyage_id%TYPE;
    v_status        voyages.voyage_status%TYPE;
BEGIN
    SELECT voyage_id, voyage_status
    INTO v_voyage_id, v_status
    FROM voyages
    WHERE voyage_number = p_voyage_number
    FOR UPDATE;

    IF v_status NOT IN ('PLANNED','UNDERWAY') THEN
        RAISE_APPLICATION_ERROR(-20010, 'Voyage ' || p_voyage_number || ' cannot depart; current status: ' || v_status);
    END IF;

    UPDATE voyages
    SET atd            = p_actual_departure,
        voyage_status  = 'UNDERWAY',
        updated_at     = SYSTIMESTAMP
    WHERE voyage_id = v_voyage_id;

    COMMIT;
    DBMS_OUTPUT.PUT_LINE('Voyage ' || p_voyage_number || ' departed at ' || TO_CHAR(p_actual_departure, 'YYYY-MM-DD HH24:MI:SS'));

EXCEPTION
    WHEN NO_DATA_FOUND THEN
        RAISE_APPLICATION_ERROR(-20011, 'Voyage number ' || p_voyage_number || ' not found');
    WHEN OTHERS THEN
        ROLLBACK;
        RAISE;
END sp_depart_voyage;
/

-- 11.5 PROCEDURE: Complete a voyage (vessel arrived)
CREATE OR REPLACE PROCEDURE sp_complete_voyage (
    p_voyage_number     IN VARCHAR2,
    p_actual_arrival    IN TIMESTAMP DEFAULT SYSTIMESTAMP
) AS
    v_voyage_id         voyages.voyage_id%TYPE;
    v_vessel_id         voyages.vessel_id%TYPE;
    v_dest_port         voyages.destination_port_id%TYPE;
    v_status            voyages.voyage_status%TYPE;
BEGIN
    SELECT voyage_id, vessel_id, destination_port_id, voyage_status
    INTO v_voyage_id, v_vessel_id, v_dest_port, v_status
    FROM voyages
    WHERE voyage_number = p_voyage_number
    FOR UPDATE;

    IF v_status <> 'UNDERWAY' THEN
        RAISE_APPLICATION_ERROR(-20020, 'Voyage ' || p_voyage_number || ' is not UNDERWAY; status: ' || v_status);
    END IF;

    -- Mark voyage complete
    UPDATE voyages
    SET ata            = p_actual_arrival,
        voyage_status  = 'COMPLETED',
        updated_at     = SYSTIMESTAMP
    WHERE voyage_id = v_voyage_id;

    -- Auto-create port call record
    INSERT INTO port_calls (vessel_id, voyage_id, port_id, arrival_time, call_purpose)
    VALUES (v_vessel_id, v_voyage_id, v_dest_port, p_actual_arrival, 'TRANSIT');

    COMMIT;
    DBMS_OUTPUT.PUT_LINE('Voyage ' || p_voyage_number || ' completed. Arrived: ' || TO_CHAR(p_actual_arrival,'YYYY-MM-DD HH24:MI:SS'));

EXCEPTION
    WHEN NO_DATA_FOUND THEN
        RAISE_APPLICATION_ERROR(-20021, 'Voyage not found: ' || p_voyage_number);
    WHEN OTHERS THEN
        ROLLBACK;
        RAISE;
END sp_complete_voyage;
/

-- 11.6 PROCEDURE: Register a maritime incident
CREATE OR REPLACE PROCEDURE sp_log_incident (
    p_vessel_mmsi   IN VARCHAR2,
    p_voyage_num    IN VARCHAR2 DEFAULT NULL,
    p_incident_type IN VARCHAR2,
    p_severity      IN VARCHAR2,
    p_description   IN VARCHAR2,
    p_latitude      IN NUMBER DEFAULT NULL,
    p_longitude     IN NUMBER DEFAULT NULL,
    p_casualties    IN NUMBER DEFAULT 0,
    p_injuries      IN NUMBER DEFAULT 0,
    p_pollution     IN CHAR DEFAULT 'N'
) AS
    v_vessel_id     vessels.vessel_id%TYPE;
    v_voyage_id     voyages.voyage_id%TYPE := NULL;
BEGIN
    SELECT vessel_id INTO v_vessel_id FROM vessels WHERE mmsi = p_vessel_mmsi;

    IF p_voyage_num IS NOT NULL THEN
        BEGIN
            SELECT voyage_id INTO v_voyage_id FROM voyages WHERE voyage_number = p_voyage_num;
        EXCEPTION WHEN NO_DATA_FOUND THEN v_voyage_id := NULL;
        END;
    END IF;

    INSERT INTO incidents (
        vessel_id, voyage_id, incident_date, incident_type, severity,
        latitude, longitude, description, casualties, injuries, pollution_risk
    ) VALUES (
        v_vessel_id, v_voyage_id, SYSTIMESTAMP, p_incident_type, p_severity,
        p_latitude, p_longitude, p_description, p_casualties, p_injuries, p_pollution
    );

    COMMIT;
    DBMS_OUTPUT.PUT_LINE('Incident logged for vessel MMSI ' || p_vessel_mmsi || ': ' || p_incident_type);

EXCEPTION
    WHEN NO_DATA_FOUND THEN
        RAISE_APPLICATION_ERROR(-20030, 'Vessel MMSI ' || p_vessel_mmsi || ' not found');
    WHEN OTHERS THEN
        ROLLBACK;
        RAISE;
END sp_log_incident;
/

-- 11.7 PROCEDURE: Search vessels (flexible)
CREATE OR REPLACE PROCEDURE sp_search_vessels (
    p_search_term   IN VARCHAR2 DEFAULT NULL,
    p_type_code     IN VARCHAR2 DEFAULT NULL,
    p_status        IN VARCHAR2 DEFAULT NULL,
    p_flag          IN CHAR DEFAULT NULL
) AS
    v_sql       VARCHAR2(2000);
    TYPE t_cur IS REF CURSOR;
    v_cur       t_cur;
    v_name      VARCHAR2(200);
    v_mmsi      VARCHAR2(9);
    v_imo       VARCHAR2(7);
    v_type      VARCHAR2(100);
    v_status    VARCHAR2(20);
    v_dwt       NUMBER;
    v_built     NUMBER;
BEGIN
    v_sql := 'SELECT v.vessel_name, v.mmsi, v.imo_number, vt.type_name, v.status, v.deadweight_tonnes, v.year_built
              FROM vessels v JOIN vessel_types vt ON v.type_code = vt.type_code
              WHERE 1=1';

    IF p_search_term IS NOT NULL THEN
        v_sql := v_sql || ' AND (UPPER(v.vessel_name) LIKE UPPER(''%' || p_search_term || '%'')
                            OR v.mmsi LIKE ''%' || p_search_term || '%''
                            OR v.imo_number LIKE ''%' || p_search_term || '%'')';
    END IF;
    IF p_type_code IS NOT NULL THEN
        v_sql := v_sql || ' AND v.type_code = ''' || p_type_code || '''';
    END IF;
    IF p_status IS NOT NULL THEN
        v_sql := v_sql || ' AND v.status = ''' || p_status || '''';
    END IF;
    IF p_flag IS NOT NULL THEN
        v_sql := v_sql || ' AND v.flag_state = ''' || p_flag || '''';
    END IF;

    v_sql := v_sql || ' ORDER BY v.vessel_name';

    OPEN v_cur FOR v_sql;
    DBMS_OUTPUT.PUT_LINE(RPAD('VESSEL NAME',40) || RPAD('MMSI',12) || RPAD('IMO',10) || RPAD('TYPE',22) || RPAD('STATUS',15) || RPAD('DWT',10) || 'BUILT');
    DBMS_OUTPUT.PUT_LINE(RPAD('-',120,'-'));
    LOOP
        FETCH v_cur INTO v_name, v_mmsi, v_imo, v_type, v_status, v_dwt, v_built;
        EXIT WHEN v_cur%NOTFOUND;
        DBMS_OUTPUT.PUT_LINE(
            RPAD(NVL(v_name,'-'),40) || RPAD(NVL(v_mmsi,'-'),12) || RPAD(NVL(v_imo,'-'),10) ||
            RPAD(NVL(v_type,'-'),22) || RPAD(NVL(v_status,'-'),15) ||
            RPAD(NVL(TO_CHAR(v_dwt),'-'),10) || NVL(TO_CHAR(v_built),'-')
        );
    END LOOP;
    CLOSE v_cur;
END sp_search_vessels;
/

